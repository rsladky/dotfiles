#!/usr/bin/env bash

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

mode="dirs"
if [[ "$1" == "--sessions" ]]; then
    mode="sessions"
fi

if [[ "$mode" == "sessions" ]]; then
    selected=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
        | fzf --height 100% --border --prompt "session: " -i --bind 'alt-j:down,alt-k:up')

    if [[ -z $selected ]]; then
        exit 0
    fi

    tmux switch-client -t "$selected"
    exit 0
fi

selected=$(find "$HOME/Perso" "$HOME/Pro" "$HOME/Ecole" -mindepth 1 -maxdepth 1 -type d 2>/dev/null \
    | fzf --height 100% --border --prompt "session: " -i --bind 'alt-j:down,alt-k:up')

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$selected_name"
