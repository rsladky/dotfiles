{
  "title": "Caps Lock: tap=Esc, hold+hjkl=arrows",
  "rules": [
    {
      "description": "Caps Lock: tap=Esc, hold+hjkl=arrows (Shift to select)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "set_variable": { "name": "caps_mode", "value": 1 } }],
          "to_after_key_up": [{ "set_variable": { "name": "caps_mode", "value": 0 } }],
          "to_if_alone": [{ "key_code": "escape" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "h", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "left_arrow" }],
          "conditions": [{ "type": "variable_if", "name": "caps_mode", "value": 1 }]
        },
        {
          "type": "basic",
          "from": { "key_code": "j", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "down_arrow" }],
          "conditions": [{ "type": "variable_if", "name": "caps_mode", "value": 1 }]
        },
        {
          "type": "basic",
          "from": { "key_code": "k", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "up_arrow" }],
          "conditions": [{ "type": "variable_if", "name": "caps_mode", "value": 1 }]
        },
        {
          "type": "basic",
          "from": { "key_code": "l", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "right_arrow" }],
          "conditions": [{ "type": "variable_if", "name": "caps_mode", "value": 1 }]
        }
      ]
    }
  ]
}
